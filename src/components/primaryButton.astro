---
let {icon, title, href} = Astro.props;
---
<a
  href={href}
  rel="noopener noreferrer"
  class="group/primarybtn inline-flex items-center gap-2.5 px-6 py-3 rounded-full border-2 border-secondary_brand bg-transparent text-secondary_brand hover:bg-secondary_brand hover:text-white font-semibold text-base tracking-wide transition-all duration-300"
>
  <span class={`${icon} group-hover/primarybtn:hidden text-lg`}></span>
  <span class="icon-[ph--arrow-right] hidden group-hover/primarybtn:block text-lg transition-transform group-hover/primarybtn:translate-x-0.5"></span>
  <span>{title}</span>
</a>
