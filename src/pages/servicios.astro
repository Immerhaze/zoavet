---
import Layout from "../layouts/Layout.astro"
import ServiciosBanners from "@/sections/servicios/ServiciosBanners.astro"
import ServiciosStaff from "@/sections/servicios/ServiciosStaff.astro"
import ServiciosTech from "@/sections/servicios/ServiciosTech.astro"
import ServiciosSteps from "@/sections/servicios/ServiciosSteps.astro"
import Footer from '@/sections/Footer.astro';
---

<Layout description="Zoavet es una clínica veterinaria que cuenta con todo tipo de servicios de salud para tus mascotas, ofreciendo servicios desde consultas y prevención hasta urgencias." title="Zoavet - Servicios">
  <!-- Section intro -->
  <div class="px-5 pt-16 pb-8">
    <p class="text-xs font-semibold tracking-[0.2em] uppercase text-secondary_brand mb-3">Nuestros servicios</p>
    <h2 class="service-title text-3xl md:text-5xl lg:text-6xl font-semibold tracking-tight text-secondary_dark animate-fade-in-up animate-delay-200 animate-duration-300 mb-5">
      Medicina <span class="text-primary_brand">Preventiva</span>
    </h2>
    <p class="text-base md:text-lg text-secondary_dark/70 font-light max-w-2xl leading-relaxed">
      En Zoavet creemos en la medicina preventiva para asegurar la salud y bienestar de tu mascota. Conoce nuestra lista completa de servicios integrales.
    </p>
  </div>

  <main>
    <!-- Featured services -->
    <section class="grid grid-cols-1 md:grid-cols-2 gap-5 px-5 mb-8">
      <div class="group rounded-3xl overflow-hidden bg-primary_light hover:bg-primary_brand transition-colors duration-300">
        <img src="/serviceBanners/domiciliary-visit.webp" alt="Veterinario visitando una mascota en su hogar" class="w-full h-52 object-cover" />
        <div class="p-6">
          <h3 class="text-xl font-semibold text-primary_brand group-hover:text-white transition-colors duration-300 mb-2">Visitas Domiciliarias</h3>
          <p class="text-sm text-secondary_dark/70 group-hover:text-white/80 transition-colors duration-300 mb-5 leading-relaxed">
            Nuestro equipo visita tu hogar para brindar atención médica personalizada a tu mascota en la comodidad de tu casa.
          </p>
          <a href="/agendamiento" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-semibold bg-secondary_brand text-white hover:bg-secondary_brand/90 transition-all duration-200">
            Solicitar Visita
            <span class="icon-[ph--arrow-right]"></span>
          </a>
        </div>
      </div>

      <div class="group rounded-3xl overflow-hidden bg-primary_light hover:bg-primary_brand transition-colors duration-300">
        <img src="/serviceBanners/telemedicine-consult.webp" alt="Consulta veterinaria por video llamada" class="w-full h-52 object-cover" />
        <div class="p-6">
          <h3 class="text-xl font-semibold text-primary_brand group-hover:text-white transition-colors duration-300 mb-2">Consultas por Telemedicina</h3>
          <p class="text-sm text-secondary_dark/70 group-hover:text-white/80 transition-colors duration-300 mb-5 leading-relaxed">
            Accede a atención de calidad para tu mascota sin salir de casa. Agendamos tu consulta en línea rápidamente.
          </p>
          <a href="/agendamiento" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-semibold bg-secondary_brand text-white hover:bg-secondary_brand/90 transition-all duration-200">
            Agendar Consulta
            <span class="icon-[ph--arrow-right]"></span>
          </a>
        </div>
      </div>
    </section>
    <ServiciosBanners/>
    <ServiciosStaff/>
    <ServiciosTech/>
    <ServiciosSteps/>
  </main>
  <Footer/>
</Layout>

<script>
  import gsap from "gsap"; 
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  //  Banners containe animation

  gsap.to(".banner-container", {
   scrollTrigger: {
     trigger: ".service-title",
     start: "bottom top",
     end:"bottom top",
     toggleActions: "play none reverse none",
   },
   marginTop:0,
   ease: "power1.out",
   duration: 1 ,
  });

// __Banners mobile and tablet animations
  let height: number;
  const divElement = document.querySelector(".banner-0"); 
  
  if (divElement instanceof HTMLElement) {
   height = divElement.offsetHeight;
  } else {
   console.error("Element not found or not an HTMLElement");
  }
  gsap.registerPlugin(ScrollTrigger);

  const setupBannerAnimations = (bannerIndex: number) => {
  const selectorPrefix = `.banner-${bannerIndex}`;
  
  const scrollTriggerSettings = {
    trigger: selectorPrefix,
    start: "center-=240px bottom-=240",
    end: "center-=240px top",
    toggleActions: "play reset play reset",
  };

  const commonAnimationProps = {
    marginTop: 0,
    ease: "power1.out",
    duration: 0.3,
  };

  gsap.to(`${selectorPrefix}`, {
    scrollTrigger: scrollTriggerSettings,
    backgroundColor: "#e67658",
    ...commonAnimationProps,
  });

  gsap.to(`${selectorPrefix}-image`, {
    scrollTrigger: scrollTriggerSettings,
    opacity: 1,
    ...commonAnimationProps,
  });

  gsap.to(`${selectorPrefix}-title`, {
    scrollTrigger: scrollTriggerSettings,
    color: "white",
    ...commonAnimationProps,
  });

  gsap.to(`${selectorPrefix}-text`, {
    scrollTrigger: scrollTriggerSettings,
    color: "white",
    ...commonAnimationProps,
  });

  gsap.to(`${selectorPrefix}-btn-comp`, {
    scrollTrigger: scrollTriggerSettings,
    borderColor: "white",
    backgroundColor: "white",
    ...commonAnimationProps,
  });

  gsap.to(`${selectorPrefix}-btn-icon`, {
    scrollTrigger: scrollTriggerSettings,
    display: 'hidden',
    ...commonAnimationProps,
  });

  gsap.to(`${selectorPrefix}-btn-text`, {
    scrollTrigger: scrollTriggerSettings,
    display: 'block',
    color: "#e67658",
    ...commonAnimationProps,
  });
};

const setupAnimations = () => {
  // Apply animations to all banners from 0 to 12
  for (let i = 0; i <= 12; i++) {
    setupBannerAnimations(i);
  }
};

const init = () => {
  let height: number;
  const divElement = document.querySelector(".banner-0");
  
  if (divElement instanceof HTMLElement) {
    height = divElement.offsetHeight;
    setupAnimations();
  } else {
    console.error("Element not found or not an HTMLElement");
  }
};

const breakPoint = gsap.matchMedia();

breakPoint.add("(max-width: 768px)", init);

// servicios staff animation
gsap.fromTo(".staff-title", 
  {
    y: 100, // Start from 100px below the normal position
    opacity: 0 // Start invisible
  }, 
  {
    y: 0, // End at the normal position
    opacity: 1, // End fully visible
    scrollTrigger: {
      trigger: ".banner-11",
      start: "top top",
      end: "top top",
      toggleActions: "play none none none",
    },
    ease: "power1.out",
    duration: 1,
  }
);
 gsap.fromTo(".staff-p", 
  {
    y: 100, // Start from 100px below the normal position
    opacity: 0 // Start invisible
  }, 
  {
    y: 0, // End at the normal position
    opacity: 1, // End fully visible
    scrollTrigger: {
      trigger: ".banner-11",
      start: "top top",
      end: "top top",
      toggleActions: "play none none none",
    
    },
    delay:0.5,
    ease: "power1.out",
    duration: 1,
  }
);

gsap.fromTo(".tech-title", 
  {
    y: 100, // Start from 100px below the normal position
    opacity: 0 // Start invisible
  }, 
  {
    y: 0, // End at the normal position
    opacity: 1, // End fully visible
    scrollTrigger: {
      trigger: ".staff-p",
      start: "top center",
      end: "top center",
      toggleActions: "play none reverse none",
    },
    ease: "power1.out",
    duration: 1,
  }
);
 gsap.fromTo(".tech-p", 
  {
    y: 100, // Start from 100px below the normal position
    opacity: 0 // Start invisible
  }, 
  {
    y: 0, 
    opacity: 1, 
    scrollTrigger: {
      trigger: ".staff-p",
      start: "top center",
      end: "top center",
      toggleActions: "play none reverse none",
    
    },
    delay:0.5,
    ease: "power1.out",
    duration: 1,
  }
);

// Steps animations with gsap
gsap.fromTo(".steps-1", 
  {
    y: 100,
    opacity: 0 
  }, 
  {
    y: 0, 
    opacity: 1, 
    scrollTrigger: {
      trigger: ".tech",
      start: "center center",
      end: "center center",
      toggleActions: "play none none none"
    },
    delay:0.5,
    ease: "power1.out",
    duration: 1,
  }
);

gsap.fromTo(".steps-2", 
  {
    y: 100,
    opacity: 0 
  }, 
  {
    y: 0, 
    opacity: 1, 
    scrollTrigger: {
      trigger: ".tech",
      start: "center center",
      end: "center center",
      toggleActions: "play none none none", 
    },
    delay:1,
    ease: "power1.out",
    duration: 1,
  }
);

gsap.fromTo(".steps-3", 
  {
    y: 100,
    opacity: 0
  }, 
  {
    y: 0, 
    opacity: 1, 
    scrollTrigger: {
    trigger: ".tech",
      start: "center center",
      end: "center center",
      toggleActions: "play none none none",
    },
    delay:1.5,
    ease: "power1.out",
    duration: 1,
  }
  );
</script>