---
import Layout from "@/layouts/Layout.astro";
import PrimaryButton from "@/components/primaryButton.astro";
import LogoZoa from "@/icons/logo_zoa.astro";
---

<Layout title="Zoavet | 404" description="Página no encontrada.">
  <section class="relative w-full min-h-[80vh] flex items-center justify-center p-5">
    <!-- Background image -->
    <div class="absolute inset-0 flex justify-center items-center pointer-events-none">
      <img
        alt="Ilustración gato buscando"
        class="w-full h-full object-contain opacity-10 md:w-1/2 lg:w-1/3"
        src="/404bg.webp"
      />
    </div>

    <!-- Content -->
    <div class="relative z-10 flex flex-col items-center text-center gap-6">
      <LogoZoa logoClassName="w-40 md:w-56" />
      <div>
        <p class="text-xs font-semibold tracking-[0.2em] uppercase text-secondary_brand mb-3">Error 404</p>
        <h1 class="text-3xl md:text-5xl font-semibold tracking-tight text-secondary_dark mb-3">
          Página no encontrada
        </h1>
        <p class="text-base text-secondary_dark/60 font-light max-w-md">
          Lo sentimos, la página que buscas no existe o fue movida.
        </p>
      </div>
      <PrimaryButton title="Volver al inicio" icon="icon-[ph--house]" href="/" />
    </div>
  </section>
</Layout>
