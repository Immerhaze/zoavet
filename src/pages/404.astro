---
import Layout from "@/layouts/Layout.astro";
import PrimaryButton from "@/components/primaryButton.astro";
import LogoZoa from "@/icons/logo_zoa.astro";
---

<Layout title="Zoavet | error 404" description="Pagina no encontrada, error 404.">
  <section class="relative w-full bg-primary_light/40 h-screen p-5">
    <div class="relative z-20  w-full h-full flex flex-col items-center">
        <LogoZoa logoClassName="w-1/2 my-10 md:mb-10"/>
      <span class="w-full h-1/2 flex justify-center text-center md:text-left">
          <h1 class="text-2xl md:text-4xl lg:text-5xl font-normal tracking-wide text-primary uppercase ">
            <span class="text-secondary font-bold"> Error 404</span> - Página no encontrada 
        </h1>
    </span>
      <span class="w-full h-1/2 flex justify-center items-center">
        <PrimaryButton
        title="Volver a inicio"
        icon="icon-[streamline--add-circle]"
        href="/"
        />
    </span>
    </div>
    <div class="absolute inset-0 z-10 flex justify-center">
      <img alt="Ilustracion, gato  buscando una botella de leche" class="w-full h-full object-contain md:w-1/2 lg:w-1/3" src="/404bg.webp" alt="404 Background">
    </div>
  </section>
</Layout>
