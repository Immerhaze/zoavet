---
import Layout from "@/layouts/Layout.astro";
import Calendario from "@/components/agendamiento/Calendario";
---

<Layout title="Zoavet | Agendamiento" description="Agenda tu cita de manera fácil y rápida con Zoavet.">
  <section class="w-full flex flex-col justify-center items-center p-4">
    <div class="text-center max-w-2xl">
      <h1 class="text-4xl font-bold text-blue-600">¡Agenda la salud de tu mascota con Zoavet!</h1>
      <p class="mt-4 text-lg text-gray-700">
        Selecciona el mejor horario para ti y tu mascota. Ofrecemos atención especializada en un entorno amigable.
      </p>
      <a href="#calendario" class="mt-6 inline-block bg-blue-600 text-white px-6 py-3 rounded-lg shadow-lg hover:bg-blue-700">
        Ir al calendario
      </a>
    </div>
  </section>

  <section id="calendario" class="w-full py-8">
    <h2 class="text-3xl font-semibold text-center text-gray-800 mb-4">Selecciona tu horario</h2>
    <div class="max-w-4xl mx-auto">
      <Calendario />
    </div>
  </section>
</Layout>
