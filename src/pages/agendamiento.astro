---
import Layout from "@/layouts/Layout.astro";
import Calendario from "@/components/agendamiento/Calendario";
---

<Layout title="Zoavet | Agendamiento" description="Agenda tu cita de manera fácil y rápida con Zoavet.">
  <div class="w-full px-4 md:px-5 py-12 flex flex-col gap-10">

    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto">
      <p class="text-xs font-semibold tracking-[0.2em] uppercase text-secondary_brand mb-3">Citas</p>
      <h1 class="text-3xl md:text-5xl font-semibold tracking-tight text-secondary_dark mb-4">
        Agenda la salud de tu mascota
      </h1>
      <p class="text-base text-secondary_dark/60 font-light leading-relaxed">
        Selecciona el mejor horario para ti y tu mascota. Ofrecemos atención especializada en un entorno amigable.
      </p>
      <a
        href="#calendario"
        class="inline-flex items-center gap-2 mt-6 px-6 py-3 rounded-full border-2 border-secondary_brand text-secondary_brand hover:bg-secondary_brand hover:text-white font-semibold text-sm transition-all duration-300"
      >
        Ver calendario
        <span class="icon-[ph--arrow-down]"></span>
      </a>
    </div>

    <!-- Calendar -->
    <section id="calendario" class="w-full rounded-3xl bg-primary_light p-6 md:p-10">
      <h2 class="text-xl md:text-2xl font-semibold text-secondary_dark mb-6">Selecciona tu horario</h2>
      <div class="max-w-4xl mx-auto">
        <Calendario />
      </div>
    </section>

  </div>
</Layout>
