---
import Layout from '@/layouts/Layout.astro';
import Footer from '@/sections/Footer.astro';
---

<Layout title="Zoavet - Tour Virtual" description="Explora nuestra clínica veterinaria de manera virtual con el tour en 3D. Conoce nuestras instalaciones de manera interactiva.">
  <section class="w-full px-4 md:px-5 py-12 flex flex-col gap-8">

    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto">
      <p class="text-xs font-semibold tracking-[0.2em] uppercase text-secondary_brand mb-3">Instalaciones</p>
      <h1 class="text-3xl md:text-5xl font-semibold tracking-tight text-secondary_dark mb-4">
        Tour Virtual de la Clínica
      </h1>
      <p class="text-base text-secondary_dark/60 font-light leading-relaxed">
        Explora nuestras instalaciones y navega por la clínica con un solo clic. Haz clic y arrastra para moverte.
      </p>
    </div>

    <!-- 3D Tour embed -->
    <div class="w-full rounded-3xl overflow-hidden border border-primary_light shadow-sm" style="height: clamp(400px, 70vh, 700px);">
      <iframe
        src="https://www.google.com/maps/embed?pb=!4v1611838377892!6m8!1m7!1sCAoSLEFGMVFpcE9aaER6dWdGZTgzVmRveGlRYlV0a3lWTGpNRXB3S1BQbTl2dm9F!2m2!1d40.748817!2d-73.985428!3f23.3!4f1.5!5f0.1"
        width="100%"
        height="100%"
        style="border:0;"
        allowfullscreen
        loading="lazy"
        title="Tour Virtual Zoavet"
      ></iframe>
    </div>

    <!-- CTA -->
    <div class="text-center">
      <a
        href="https://www.google.com/maps/@?api=1&map_action=pano&viewpoint=40.748817,-73.985428"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full font-semibold text-sm text-white bg-primary_brand hover:bg-primary_brand/90 transition-all duration-200 shadow-sm"
      >
        <span class="icon-[ph--arrows-out] text-lg"></span>
        Abrir en pantalla completa
      </a>
    </div>

  </section>
  <Footer />
</Layout>
