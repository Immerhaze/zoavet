---
import Accordion from '../sections/fqa/accordion';
import Layout from '@/layouts/Layout.astro';
import Testimonials from '@/components/fqa/Testimonials';
import Footer from '@/sections/Footer.astro';
---

<Layout title="Zoavet - Preguntas Frecuentes" description="Descubre cómo cuidar a tu mascota responsablemente y encuentra respuestas a preguntas frecuentes.">
  <div class="w-full px-4 md:px-5 py-12 flex flex-col gap-12">

    <!-- Header -->
    <div class="text-center">
      <p class="text-xs font-semibold tracking-[0.2em] uppercase text-secondary_brand mb-3">Información útil</p>
      <h1 class="text-3xl md:text-5xl font-semibold tracking-tight text-secondary_dark mb-4">Tenencia Responsable</h1>
      <p class="text-base text-secondary_dark/60 font-light max-w-xl mx-auto leading-relaxed">
        Descubre cómo cuidar a tu mascota responsablemente y encuentra respuestas a las preguntas más frecuentes.
      </p>
    </div>

    <!-- Compromiso section -->
    <section class="rounded-3xl bg-primary_light p-6 md:p-10">
      <h2 class="text-xl md:text-2xl font-semibold text-secondary_dark mb-2">Compromiso con la Tenencia Responsable</h2>
      <p class="text-sm md:text-base text-secondary_dark/70 font-light leading-relaxed mb-6">
        En Zoavet, creemos que la tenencia responsable es la clave para asegurar el bienestar de las mascotas y su integración adecuada en la sociedad. Promovemos el cuidado responsable y prevenimos el abandono animal.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <div class="bg-white rounded-2xl p-5 border border-primary_brand/10">
          <h3 class="text-base font-semibold text-secondary_dark mb-2">Educación y Concientización</h3>
          <p class="text-sm text-secondary_dark/60 font-light leading-relaxed">
            Brindamos talleres, charlas y actividades interactivas sobre cuidados básicos, salud animal y prevención del abandono.
          </p>
        </div>
        <div class="bg-white rounded-2xl p-5 border border-primary_brand/10">
          <h3 class="text-base font-semibold text-secondary_dark mb-2">Campañas de Tenencia Responsable</h3>
          <p class="text-sm text-secondary_dark/60 font-light leading-relaxed">
            Realizamos campañas anuales con adopciones responsables, esterilización y vacunación para fomentar el bienestar animal.
          </p>
        </div>
      </div>
    </section>

    <!-- Testimonials -->
    <Testimonials client:load />

    <!-- FAQ Accordion -->
    <section class="rounded-3xl bg-primary_light p-6 md:p-10">
      <p class="text-xs font-semibold tracking-[0.2em] uppercase text-secondary_brand mb-3">Dudas frecuentes</p>
      <h2 class="text-2xl md:text-3xl font-semibold text-secondary_dark mb-6">Preguntas Frecuentes</h2>
      <Accordion preguntas={[
        { pregunta: "¿Qué cuidados necesita una mascota recién adoptada?", respuesta: "Es importante programar una revisión veterinaria inicial, establecer un plan de vacunas y desparasitación, y preparar un entorno seguro y cómodo." },
        { pregunta: "¿Cómo identificar si mi mascota está enferma?", respuesta: "Signos como cambios en el apetito, letargo, vómitos, diarrea, o comportamientos inusuales pueden indicar enfermedad. Consulta con un veterinario si notas algo inusual." },
        { pregunta: "¿Por qué es importante esterilizar o castrar a mi mascota?", respuesta: "Ayuda a prevenir problemas de salud, reduce comportamientos no deseados, y contribuye al control de la población animal." },
        { pregunta: "¿Qué debe incluir una dieta equilibrada para mi mascota?", respuesta: "Debe incluir proteínas, carbohidratos, grasas, vitaminas y minerales en cantidades adecuadas. Consulta con un veterinario para una dieta específica." },
        { pregunta: "¿Cómo mantener la salud dental de mi mascota?", respuesta: "Cepilla sus dientes regularmente con productos específicos para mascotas y ofrece juguetes o snacks que promuevan la salud bucal." }
      ]} client:load />
    </section>

    <!-- Tips -->
    <section>
      <p class="text-xs font-semibold tracking-[0.2em] uppercase text-secondary_brand mb-3">Recomendaciones</p>
      <h2 class="text-2xl md:text-3xl font-semibold text-secondary_dark mb-6">Consejos para la Tenencia Responsable</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          { title: "Cuidado Regular", desc: "Programa visitas periódicas al veterinario y mantén al día las vacunas de tu mascota." },
          { title: "Ejercicio Diario", desc: "Asegúrate de que tu mascota reciba suficiente ejercicio para mantenerse activa y saludable." },
          { title: "Identificación Adecuada", desc: "Usa un collar con identificación y considera implantar un microchip para mayor seguridad." },
          { title: "Socialización", desc: "Socializa a tu mascota desde temprana edad para que sea amistosa y se adapte bien a diferentes entornos." },
          { title: "Ambiente Seguro", desc: "Asegúrate de que el hogar esté libre de peligros y proporciónale un espacio cómodo y seguro." },
          { title: "Nutrición", desc: "Ofrece una dieta equilibrada y agua fresca siempre disponible. Consulta al veterinario sobre la alimentación ideal." },
        ].map((tip) => (
          <div class="p-5 bg-white rounded-2xl border border-primary_light hover:border-primary_brand transition-colors duration-200">
            <h3 class="text-sm font-semibold text-secondary_dark mb-2">{tip.title}</h3>
            <p class="text-sm text-secondary_dark/60 font-light leading-relaxed">{tip.desc}</p>
          </div>
        ))}
      </div>
    </section>

  </div>
  <Footer />
</Layout>
