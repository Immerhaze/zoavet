---
import EmblaCarousel from '@/components/index/staff/EmblaCarousel';
import FounderFrame from '@/components/index/staff/FounderFrame';
import { SLIDES, FOUNDERS } from '@/consts/staff';
import PrimaryButton from '@/components/primaryButton.astro'

const OPTIONS = { align: 'start', loop: true };
---

<section class="w-full px-5 py-16">
  <div class="w-full rounded-3xl bg-primary_light p-6 md:p-10 overflow-visible">

    <!-- Header -->
    <div class="service-staff-text mb-8">
      <p class="text-xs font-semibold tracking-[0.2em] uppercase text-secondary_brand mb-3">Nuestro equipo</p>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-semibold tracking-tight text-secondary_dark leading-tight mb-4">
        Tu equipo de confianza
      </h2>
      <p class="max-w-2xl text-base md:text-lg text-secondary_dark/70 font-light leading-relaxed">
        Nos enorgullece contar con un equipo médico altamente capacitado, comprometido con brindar el mejor cuidado a tus mascotas. Constantemente se actualizan en avances científicos y participan en eventos de educación continua.
      </p>
    </div>

    <!-- Founders -->
    <div class="service-staff-founder flex flex-col sm:flex-row gap-4 mb-8">
      {FOUNDERS.map((founder) => (
        <FounderFrame client:load
          id={founder.id}
          name={founder.name}
          designation={founder.designation}
          image={founder.image}
        />
      ))}
    </div>

    <!-- Team Carousel -->
    <div class="service-staff-team">
      <EmblaCarousel slides={SLIDES} options={OPTIONS} client:load />
    </div>
  </div>

  <!-- CTA -->
  <div class="flex justify-center mt-8">
    <PrimaryButton
      title="Conoce al equipo"
      icon="icon-[streamline--add-circle]"
      href="/equipo"
    />
  </div>
</section>
