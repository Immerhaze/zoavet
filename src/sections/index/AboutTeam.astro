---
import EmblaCarousel from '@/components/index/staff/EmblaCarousel';
import FounderFrame from '@/components/index/staff/FounderFrame';
import { SLIDES, FOUNDERS } from '@/consts/staff';
import PrimaryButton from '@/components/primaryButton.astro'

const OPTIONS = { align: 'start', loop: true };

---

<section class="w-full lg:h-screen p-2 md:px-5 mt-10">
    <div class="min-w-full h-full bg-primary_light p-2 rounded-2xl py-5">
        <div class="w-full lg:h-3/5  flex flex-col gap-5 ">
            <div class="service-staff-text lg:w-full flex flex-col gap-3">
                <h1 class="uppercase text-left  text-4xl md:text-6xl lg:text-7xl  font-semibold tracking-wide  text-primary lg:px-5">
                    Tu equipo de confianza
                </h1>
                <p class="text-base md:text-xl  lg:text-2xl   tracking-wide leading-relaxed font-light lg:px-5 ">
                    Nos enorgullece contar con un equipo de profesionales altamente capacitados y apasionados por el cuidado animal. Cada miembro de nuestro equipo comparte un amor genuino por los animales y se mantiene al día con los últimos avances en el campo.
                </p>
                <p class="text-base md:text-xl  lg:text-2xl   tracking-wide leading-relaxed font-light lg:px-5">
                    Nos esforzamos por brindar una atención de calidad y personalizada, asegurando que tu mascota reciba el mejor cuidado posible.
                </p>
            </div>
            <div class="service-staff-founder w-full  h-full flex flex-col lg:flex-row justify-center ">
      {FOUNDERS.map((founder) => (
          <FounderFrame client:load 
          id={founder.id}
          name={founder.name}
          designation={founder.designation}
          image={founder.image}
          />
      ))}
    </div>
</div>
<div class="service-staff-team w-full lg:h-2/5 flex flex-col justify-center items-center ">
    <EmblaCarousel slides={SLIDES} options={OPTIONS} client:load />
    <PrimaryButton  title="Conoce al equipo"
    icon="icon-[streamline--add-circle]"
    href={"equipo"}/>
  </div>
  <!-- <div class="w-full lg:h-1/3 flex justify-center items-center">
    <button class="p-3 flex flex-row justify-center items-center  rounded-full gap-2 bg-secondary text-white tracking-wide">
        <span class="icon-[streamline--add-circle] text-3xl lg:text-4xl"></span>
        <p class="font-semibold md:text-lg lg:text-3xl xl:text-4xl">
            Conoce el equipo
        </p>
    </button>
</div> -->
</div>
</section>
