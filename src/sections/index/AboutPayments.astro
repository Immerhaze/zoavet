---
const methods = [
  { title: 'Tarjetas débito y crédito', icon: "icon-[material-symbols--credit-score-outline]" },
  { title: 'Sistecrédito', icon: "/pagos/sistecredito.png" },
  { title: 'PayPal', icon: "/pagos/paypal.svg" },
  { title: 'Mercado Pago', icon: "/pagos/mercado.png" },
]
---

<section class="px-5 py-16">
  <!-- Header -->
  <div class="text-center mb-10">
    <p class="text-xs font-semibold tracking-[0.2em] uppercase text-secondary_brand mb-3">Pagos</p>
    <h2 class="text-3xl md:text-4xl lg:text-5xl font-semibold tracking-tight text-secondary_dark">
      Métodos de pago
    </h2>
    <p class="text-sm md:text-base text-secondary_dark/60 mt-3 max-w-md mx-auto font-light">
      Elige el método de pago que más te convenga.
    </p>
  </div>

  <!-- Payment methods grid -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-3xl mx-auto">
    {methods.map((method) => (
      <div class="flex flex-col items-center justify-center gap-3 p-6 bg-white rounded-2xl border border-primary_light hover:border-primary_brand hover:shadow-sm transition-all duration-300">
        {method.icon.startsWith("icon-") ? (
          <i class={`text-5xl text-primary_brand ${method.icon}`} />
        ) : (
          <img
            src={method.icon}
            class="w-16 h-16 object-contain"
            alt={method.title}
          />
        )}
        <p class="text-xs md:text-sm font-medium text-secondary_dark text-center leading-tight">{method.title}</p>
      </div>
    ))}
  </div>
</section>
