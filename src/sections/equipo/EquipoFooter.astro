---
import PrimaryButton from "@/components/primaryButton.astro"
---

<section class="w-full px-4 md:px-5 py-12">
  <div class="rounded-3xl bg-primary_light p-8 md:p-12 flex flex-col items-center text-center gap-6">
    <p class="text-xl md:text-2xl lg:text-3xl font-semibold text-secondary_dark max-w-2xl leading-relaxed">
      Al confiar el cuidado de tu mascota a nuestro equipo, puedes estar seguro de que está en manos expertas y afectuosas.
    </p>
    <PrimaryButton title="Agendar cita" icon="icon-[streamline--add-circle]" href="/agendamiento" />
  </div>
</section>
