---
import PrimaryButton  from "@/components/primaryButton.astro"
---
<section class="bg-secondary_light/30  group p-5 rounded-xl mx-2 md:mx-5">
    <div class="h-fullflex flex-col gap-3 text-center  text-secondary font-medium">
        <p class="text-2xl md:text-4xl lg:text-5xl tracking-wide">Al confiar el cuidado de tu mascota a nuestro equipo de profesionales veterinarios dedicados, puedes estar seguro de que está en manos expertas y afectuosas.</>
        <div class="w-full h-full flex flex-col justify-center items-center gap-4">
            <div class="w-full flex justify-center my-10">
                <PrimaryButton title="Agendar cita" icon="icon-[streamline--add-circle]" href="/contacto" />
            </div>
        </div>
    </div>
  </section>