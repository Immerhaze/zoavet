---
import LogoZoa from "@/icons/logo_zoa.astro";

const currentYear = new Date().getFullYear();

const navLinks = [
  { href: "/", label: "Inicio" },
  { href: "/servicios", label: "Servicios" },
  { href: "/equipo", label: "Equipo" },
  { href: "/instalaciones", label: "Instalaciones" },
  { href: "/contacto", label: "Contacto" },
  { href: "/fqa", label: "FQA" },
];
---

<footer class="w-full px-4 md:px-5 pb-5 pt-4">
  <div class="w-full rounded-3xl bg-primary_light p-6 md:p-10">

    <!-- Top: Logo + tagline -->
    <div class="mb-10 flex flex-col md:flex-row md:items-center md:justify-between gap-6">
      <LogoZoa logoClassName="w-36 md:w-44" />
      <p class="text-sm text-secondary_dark/60 font-light max-w-xs">
        Clínica veterinaria con tecnología de punta y personal especializado en Bogotá.
      </p>
    </div>

    <!-- Grid: nav, info, map -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 mb-10">

      <!-- Navigation -->
      <div>
        <h3 class="text-xs font-semibold tracking-[0.15em] uppercase text-secondary_dark mb-4">Navegación</h3>
        <ul class="flex flex-col gap-2.5">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-secondary_dark/70 hover:text-primary_brand transition-colors duration-200"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact & Hours -->
      <div>
        <h3 class="text-xs font-semibold tracking-[0.15em] uppercase text-secondary_dark mb-4">Contacto</h3>
        <ul class="flex flex-col gap-3">
          <li class="flex flex-col">
            <span class="text-xs font-semibold text-secondary_dark/50 uppercase tracking-wide mb-0.5">Horario</span>
            <span class="text-sm text-secondary_dark font-medium">8:00 am – 7:00 pm</span>
            <span class="text-xs text-secondary_brand font-semibold">Lunes a Domingo</span>
          </li>
          <li class="flex flex-col">
            <span class="text-xs font-semibold text-secondary_dark/50 uppercase tracking-wide mb-0.5">Urgencias</span>
            <span class="text-sm text-secondary_dark font-medium">24/7</span>
          </li>
          <li>
            <a href="mailto:zoavet@hotmail.com" class="text-sm text-secondary_dark/70 hover:text-primary_brand transition-colors duration-200 break-all">
              zoavet@hotmail.com
            </a>
          </li>
          <li>
            <a href="tel:6016756195" class="text-sm text-secondary_dark/70 hover:text-primary_brand transition-colors duration-200">
              (601) 675 6195
            </a>
          </li>
          <li class="flex gap-1.5 flex-col">
            <span class="text-xs font-semibold text-secondary_dark/50 uppercase tracking-wide">Dirección</span>
            <span class="text-sm text-secondary_dark/70">Carrera 113 #77-30</span>
            <span class="text-sm text-secondary_dark/70">Villas De Granada, Bogotá</span>
          </li>
        </ul>

        <!-- Social links -->
        <div class="flex gap-4 mt-5">
          <a aria-label="Instagram" href="https://www.instagram.com/zoaveterinarios/" target="_blank" rel="noopener noreferrer"
            class="icon-[lets-icons--insta-duotone-line] text-2xl text-secondary_dark/50 hover:text-primary_brand transition-colors duration-200"></a>
          <a aria-label="Facebook" href="https://www.facebook.com/zoaveterinarios/?locale=es_LA" target="_blank" rel="noopener noreferrer"
            class="icon-[ph--facebook-logo-duotone] text-2xl text-secondary_dark/50 hover:text-primary_brand transition-colors duration-200"></a>
          <a aria-label="LinkedIn" href="https://www.linkedin.com/in/z%C3%B3a-cl%C3%ADnica-867a4a218/" target="_blank" rel="noopener noreferrer"
            class="icon-[ph--linkedin-logo-duotone] text-2xl text-secondary_dark/50 hover:text-primary_brand transition-colors duration-200"></a>
        </div>
      </div>

      <!-- Map -->
      <div class="sm:col-span-2 lg:col-span-1">
        <h3 class="text-xs font-semibold tracking-[0.15em] uppercase text-secondary_dark mb-4">Ubicación</h3>
        <div class="rounded-2xl overflow-hidden border border-primary_brand/20 h-48 md:h-56">
          <iframe
            title="Mapa Zoavet"
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3976.30169041661!2d-74.12693442399332!3d4.717565795257519!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8e3f8357fed2c7a7%3A0x2cfcf2ddd4318cf1!2sZoavet%20Cl%C3%ADnica%20Veterinaria!5e0!3m2!1ses-419!2scl!4v1723820529747!5m2!1ses-419!2scl"
            class="w-full h-full"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-6 border-t border-white/80 flex flex-col sm:flex-row gap-2 items-center justify-between">
      <p class="text-xs text-secondary_dark/40 font-medium">
        &copy; {currentYear} Zoavet Clínica Veterinaria. Todos los derechos reservados.
      </p>
      <p class="text-xs text-secondary_dark/40">
        Sitio web por
        <a href="https://www.linkedin.com/in/nicolas-romero--nicode/" target="_blank" rel="noopener noreferrer"
          class="text-secondary_brand hover:text-primary_brand transition-colors duration-200 font-semibold">
          NicolasCode
        </a>
      </p>
    </div>
  </div>
</footer>
